# ── WhatsApp Business API ────────────────────────────────────────────────────
# Permanent access token from Meta developer portal (required)
TOKEN=

# Phone Number ID from Meta developer portal (required)
PHONE_NUMBER_ID=

# Token Meta uses to verify your webhook endpoint (required in production)
WA_VERIFY_TOKEN=

# App Secret from Meta developer portal — enables HMAC signature verification (recommended)
APP_SECRET=

# Graph API version to use (optional, defaults to v21.0)
WA_API_VERSION=v21.0

# WhatsApp API timeout in ms (optional, default 10000)
WA_TIMEOUT_MS=10000

# Number of retries on 429/5xx (optional, default 2)
WA_RETRY_COUNT=2

# Base backoff delay in ms (optional, default 400)
WA_RETRY_BASE_MS=400

# ── Application ──────────────────────────────────────────────────────────────
# Port to listen on (optional, default 3000)
PORT=3000

# URL to open when a user selects a loan product (required)
WEBVIEW_LINK=

# Public image URL used as the header in CTA messages (optional)
IMAGE_URL=

# ── Admin / Dashboard ────────────────────────────────────────────────────────
# Username and password for the dashboard login prompt (HTTP Basic Auth).
# Required to access /dashboard, /analytics, /api/leads/recent.
# Browsers show a native login dialog automatically.
DASHBOARD_USER=admin
DASHBOARD_PASS=

# Max inbound webhook requests per IP per minute (optional, default 120)
WEBHOOK_RATE_LIMIT=120

# ── Email Notifications (SMTP) ───────────────────────────────────────────────
# All fields optional — email notifications are silently disabled when SMTP_HOST is unset

SMTP_HOST=
SMTP_PORT=587
# Set to true for port 465 (TLS), false for STARTTLS
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Sender address (optional, defaults to SMTP_USER or no-reply@finfinity.co.in)
EMAIL_FROM=

# Recipient for intake notifications (optional, defaults to connect@finfinity.co.in)
EMAIL_TO=
